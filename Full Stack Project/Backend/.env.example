PORT=8000
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# MongoDB connection string.
# Local MongoDB (default if not set): mongodb://127.0.0.1:27017/moody_player
# Or a MongoDB Atlas (cloud) URI, e.g.:
# mongodb+srv://<user>:<password>@<cluster>.mongodb.net/moody_player
MONGODB_URL=mongodb://127.0.0.1:27017/moody_player

# Optional — only needed if you want audio files stored on ImageKit's cloud CDN
# instead of the default local Backend/uploads folder. Leave blank to use local storage.
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
